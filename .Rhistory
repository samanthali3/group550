age_music <- music_data %>%
mutate(
age_group = case_when(
Age <= 12 ~ "Children",
Age <= 19 ~ "Teenager",
Age <= 40 ~ "Young Adult",
Age <= 59 ~ "Middle Aged",
Age > 59 ~ "Older Adult"
)
)
age_table <- table(age_music$age_group, age_music$`Music effects`)
age_table
