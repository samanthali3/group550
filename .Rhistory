geom boxplot()+
ggplot(music_data, aes(x = `Music effects`, y = `Hours per day`))+
geom_boxplot()+
labs(
title = "Hours of Music per Day by Music Effect on Mental Health",
x = "Music Effect on Mental Health",
y = "Hours per Day"
)
ggplot(music_data, aes(x = `Music effects`, y = `Hours per day`))+
geom_boxplot(na.rm = TRUE)+
labs(
title = "Hours of Music per Day by Music Effect on Mental Health",
x = "Music Effect on Mental Health",
y = "Hours per Day"
)
